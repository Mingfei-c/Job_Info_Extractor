# Environment variable configuration example
# Copy this file to .env and fill in your actual values

# PostgreSQL database connection (Unix socket, for WSL)
DATABASE_URL=postgresql://mingfei-c@/jobs_db

# For TCP connection (requires password):
# DATABASE_URL=postgresql://job_user:your_password@localhost:5432/jobs_db

# Adzuna API configuration
# Get credentials at: https://developer.adzuna.com/
ADZUNA_APP_ID=your_app_id
ADZUNA_APP_KEY=your_app_key
ADZUNA_COUNTRY=us

# Google Gemini API Key (used for LLM features)
GOOGLE_API_KEY=your_gemini_api_key_here

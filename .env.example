# 环境变量配置示例
# 复制此文件为 .env 并填入你的实际值

# PostgreSQL 数据库连接（Unix Socket 方式，用于 WSL）
DATABASE_URL=postgresql://mingfei-c@/jobs_db

# 如果使用 TCP 连接（需要密码）:
# DATABASE_URL=postgresql://job_user:your_password@localhost:5432/jobs_db

# Adzuna API 配置
# 获取地址: https://developer.adzuna.com/
ADZUNA_APP_ID=your_app_id
ADZUNA_APP_KEY=your_app_key
ADZUNA_COUNTRY=us

# Google Gemini API Key (用于后续 LLM 功能)
GOOGLE_API_KEY=your_gemini_api_key_here
